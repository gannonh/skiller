{
  "name": "@skiller/desktop",
  "version": "0.3.0",
  "description": "Desktop skill manager for agent skills",
  "author": {
    "name": "Gannon Hall",
    "email": "gannonhall@gmail.com"
  },
  "homepage": "https://github.com/gannonh/skiller",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "pnpm run build && node dist/main/dev-server.js",
    "dev:renderer": "vite --host 127.0.0.1",
    "build": "tsc -b ../../packages/core tsconfig.json --force && vite build",
    "desktop:pack": "pnpm run build && electron-builder --config electron-builder.yml --dir",
    "desktop:dist": "pnpm run build && electron-builder --config electron-builder.yml",
    "desktop:dist:mac": "pnpm run build && electron-builder --config electron-builder.yml --mac dmg zip",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.2",
    "@hugeicons/react": "^1.1.6",
    "@skiller/core": "workspace:*",
    "@vitejs/plugin-react": "^4.3.0",
    "@workspace/ui": "workspace:^",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.18"
  }
}
