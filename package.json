{
  "name": "skiller",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm --filter @skiller/core --filter @skiller/cli --filter @skiller/desktop build",
    "typecheck": "pnpm --filter @skiller/core build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "check": "pnpm typecheck && pnpm test:coverage && pnpm test:release-scripts && pnpm test:e2e && pnpm build",
    "test:release-scripts": "vitest run --config scripts/release/vitest.config.ts",
    "dev": "pnpm --filter @skiller/desktop dev",
    "dev:renderer": "pnpm --filter @skiller/desktop dev:renderer",
    "cli": "pnpm --filter @skiller/cli start",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "yaml": "^2.8.3",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
